generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id          Int       @id @default(autoincrement())
  nomeEmpresa String    @unique
  email       String    @unique
  senha       String    @unique
  CNPJ        String    @unique
  numero      String    @unique
  status      Boolean   @default(false)
  saldo       Int?      @default(0)
  cliente     Cliente[]
  IA          IA[]
}

model Company_Pending {
  id            Int      @id @default(autoincrement())
  nome          String   @unique
  email         String   @unique
  senha         String   @unique
  CNPJ          String   @unique
  numero        String   @unique
  token         String
  token_expires DateTime
  created_at    DateTime @default(now())
}

model Cliente {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])
  nome      String?
  contato   String   @unique
  data      DateTime @default(now())
  status    Boolean  @default(false)
}

model IA {
  id           Int     @id @default(autoincrement())
  companyId    Int
  company      Company @relation(fields: [companyId], references: [id])
  nomeEmpresa  String?
  nomeIA       String?
  instructions String?
  data         Json?
}
