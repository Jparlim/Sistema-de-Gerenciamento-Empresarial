generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id          Int       @id @default(autoincrement())
  nome        String    @unique
  email       String    @unique
  senha       String
  CNPJ        String    @unique
  telefone      String    @unique
  status      Boolean   @default(true)
  saldo       Int?      @default(0)

  cliente     Cliente[]
  IA          IA?
  estoque     Estoque?
}

model Company_Pending {
  id            Int      @id @default(autoincrement())
  nome          String   @unique
  email         String   @unique
  senha         String   @unique
  CNPJ          String   @unique
  telefone        String   @unique
  token         String
  token_expires DateTime
  created_at    DateTime @default(now())
}

model Cliente {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])
  nome      String?
  contato   String   @unique
  date      DateTime @default(now())
  dados     Json?
  resumo    String
  status    String
  visits    Visits[]
}

model IA {
  id           Int     @id @default(autoincrement())
  nomeEmpresa  String?
  nomeIA       String?
  instructions String?
  data         Json?

  companyId    Int @unique
  company      Company @relation(fields: [companyId], references: [id])
}

model Visits {
  id          Int      @id @default(autoincrement())
  clientId    Int
  client      Cliente  @relation(fields: [clientId], references: [id])
  nome        String
  contato     String @unique
  endereco    String
  observacao  String
  responsavel String
  data        String
  hora        String
  status      String
}

model Estoque {
  id Int @id @default(autoincrement())

  companyId Int @unique
  company Company @relation(fields: [companyId], references: [id])

  produtos Produto[]
}

model Produto {
  id Int @id @default(autoincrement())
  nome String
  categoria String
  quantidade Int
  valor_unitario Float

  estoqueId Int
  estoque Estoque @relation(fields: [estoqueId], references: [id])

  fornecedorId Int
  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id])

  movimentacoes MovimentacaoEstoque[]
}

model MovimentacaoEstoque {
  id Int @id @default(autoincrement())

  tipo TipoMovimentacao
  quantidade Int
  motivo String
  createdAt DateTime @default(now())

  produtoId Int
  produto Produto @relation(fields: [produtoId], references: [id])
}
 
enum TipoMovimentacao {
  ENTRADA
  SAIDA
}

model Fornecedor {
  id Int @id @default(autoincrement())
  nome String
  contato String @unique
  CNPJ String @unique

  produto Produto[]
}