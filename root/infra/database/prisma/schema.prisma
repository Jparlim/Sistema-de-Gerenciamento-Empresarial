generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id          Int       @id @default(autoincrement())
  nomeEmpresa String    @unique
  email       String    @unique
  senha       String
  CNPJ        String    @unique
  telefone      String    @unique
  status      Boolean   @default(true)
  saldo       Int?      @default(0)
  cliente     Cliente[]
  IA          IA?
}

model Company_Pending {
  id            Int      @id @default(autoincrement())
  nomeEmpresa          String   @unique
  email         String   @unique
  senha         String   @unique
  CNPJ          String   @unique
  telefone        String   @unique
  token         String
  token_expires DateTime
  created_at    DateTime @default(now())
}

model Cliente {
  id        Int      @id @default(autoincrement())
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])
  nome      String?
  contato   String   @unique
  date      DateTime @default(now())
  status    String
  visits    Visits[]
}

model IA {
  id           Int     @id @default(autoincrement())
  companyId    Int @unique
  company      Company @relation(fields: [companyId], references: [id])
  nomeEmpresa  String?
  nomeIA       String?
  instructions String?
  data         Json?
}

model Visits {
  id          Int      @id @default(autoincrement())
  clientId    Int
  client      Cliente  @relation(fields: [clientId], references: [id])
  nome        String
  contato     String
  endereco    String
  observacao  String
  responsavel String
  data        DateTime
  hora        String
  status      Boolean  @default(false)
}
